APP_NAME=FaceHRM
APP_ENV=local          # production: ganti ke "production"
APP_KEY=
APP_DEBUG=true         # production: WAJIB false — stack trace disembunyikan dari API response
APP_URL=http://localhost

LOG_CHANNEL=stack      # production: ganti ke "daily" untuk rotasi otomatis
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug        # production: ganti ke "info" (kurangi noise)
LOG_DAILY_DAYS=30      # production: simpan 30 hari log

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=facehrm
DB_USERNAME=facehrm_user
DB_PASSWORD=facehrm_secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
